# Kurv Payment Integration Configuration
# Copy these to your .env.local and fill in with actual values from Kurv dashboard

# Public key for Kurv checkout (safe to expose to frontend)
NEXT_PUBLIC_KURV_KEY=your_kurv_public_api_key_here

# Secret key for Kurv API calls (keep private, backend only)
KURV_SECRET_KEY=your_kurv_secret_api_key_here

# Webhook signature secret for verifying incoming webhooks from Kurv
KURV_WEBHOOK_SECRET=your_kurv_webhook_secret_here

# Optional: Kurv API environment (sandbox for testing, production for live)
NEXT_PUBLIC_KURV_ENVIRONMENT=sandbox
# NEXT_PUBLIC_KURV_ENVIRONMENT=production

# Webhook endpoint URL that Kurv will send events to
# This should be: https://yourdomain.com/api/kurv-webhook
KURV_WEBHOOK_URL=https://yourdomain.com/api/kurv-webhook
